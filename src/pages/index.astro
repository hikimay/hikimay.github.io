  <!-- randomly change the profile image on each page load -->
  <script>
    window.addEventListener("DOMContentLoaded", () => {
      const image = document.querySelector<HTMLImageElement>("#profileImage");

      if (!image) return;

      // const images = [
      //   "/hikimay_icon_2026.png",
      //   "/hikimay_icon_2025.png",
      // ];
      // const randomIndex = Math.floor(Math.random() * images.length);
      // image.src = images[randomIndex];

      const images = [
        { src: "/hikimay_icon_2026.png", alt: "personal photo (2026)", probability: 0.75 },
        { src: "/hikimay_icon_2025.png", alt: "personal photo (2025)", probability: 0.25 },
      ]

      const randomValue = Math.random();
      let cumulativeProbability = 0;

      for (const { src, alt, probability } of images) {
        cumulativeProbability += probability;
        if (randomValue < cumulativeProbability) {
          image.src = src;
          image.alt = alt;
          break;
        }
      }
    });
  </script>
